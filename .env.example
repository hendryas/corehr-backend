NODE_ENV=development
LOG_LEVEL=debug
PORT=3000
CORS_ORIGIN=http://localhost:4200,http://127.0.0.1:4200

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=corehr_db

JWT_SECRET=replace_with_a_long_random_secret_key
JWT_EXPIRES_IN=1d

